# InfoWatchtower intranet（内网嵌入形态）环境模板。
# 复制到 /srv/infowatchtower/.env.intranet 并替换所有 REPLACE_WITH_* 值，不要提交真实密钥。
# 配套 compose：deploy/docker-compose.intranet.yml；门户侧反代样例：deploy/nginx.portal.example.conf。
# 形态约束（config/contracts/deployment_modes.json）：禁采集（不可覆盖打开）、pull-only、
# backend 仅可信网关可达、评论/点赞/采信留在内网库不回流 extranet。

APP_ENV=production
APP_VERSION=0.1.0
# 门户以同站子路径承载，基址是门户域 + 子路径。
APP_BASE_URL=https://portal.example.com/watchtower
ENABLE_DOCS=false
CORS_ORIGINS=https://portal.example.com

# ---- 部署拓扑 ----
DEPLOY_MODE=intranet
INSTANCE_ID=intranet-main
# intranet 默认开启 CSRF（双提交 cookie），不要设为 false。
AUTH_CSRF_ENABLED=true
# 门户域白名单：HTML 与 API 响应输出 frame-ancestors，允许门户 iframe 嵌入本系统。
EMBED_FRAME_ANCESTORS="'self' https://portal.example.com"
# 可选兜底：非空时 backend 校验直连来源必须落在可信网关网段内（逗号分隔 CIDR）。
AUTH_TRUSTED_PROXY_CIDRS=

DATABASE_URL=postgresql+psycopg://infowatchtower:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@postgres:5432/infowatchtower
REDIS_URL=redis://redis:6379/0

BACKUP_KEEP=14

POSTGRES_DB=infowatchtower
POSTGRES_USER=infowatchtower
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD

# intranet 强制 intranet_header（其他组合启动 fail-fast）：身份头由可信门户网关注入，
# 自动建号默认 viewer；业务权限仍走本地 RBAC，不由 header 直接决定管理员权限。
AUTH_MODE=intranet_header
AUTH_SESSION_SECRET=REPLACE_WITH_32_BYTE_RANDOM_SESSION_SECRET
AUTH_SESSION_COOKIE=infowatchtower_session
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=43200
AUTH_AUTO_PROVISION=true
AUTH_DEFAULT_ROLE=viewer

AUTH_HEADER_EMPLOYEE_NO=X-Employee-No
AUTH_HEADER_DISPLAY_NAME=X-Employee-Name
AUTH_HEADER_DEPARTMENT=X-Department
AUTH_HEADER_EMAIL=X-Email

# ---- 同步拉取（sync consumer）----
# 从 extranet feed 拉已采集/已成稿数据；方向单向 extranet -> intranet，绝不回流。
SYNC_REMOTE_BASE_URL=https://extranet.example.com
SYNC_REMOTE_TOKEN=REPLACE_WITH_SYNC_REMOTE_TOKEN
SYNC_PULL_ENABLED=true
SYNC_PULL_INTERVAL_SECONDS=900
SYNC_FAILED_INBOX_AUTO_RETRY_ENABLED=true
SYNC_FAILED_INBOX_RETRY_BASE_SECONDS=300
SYNC_FAILED_INBOX_RETRY_MAX_SECONDS=3600
SYNC_FAILED_INBOX_RETRY_MAX_ATTEMPTS=5
SYNC_FAILED_INBOX_RETRY_LIMIT=50

# intranet 禁采集：采集 capability 关死，调度器不会投递采集任务；
# 但 scheduler 进程仍要跑（按 SYNC_PULL_INTERVAL_SECONDS 投递 sync_pull）。
INGESTION_SCHEDULER_ENABLED=false
INGESTION_SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_JOB_MODE=daily_pipeline

# ---- compose 侧变量（不进 backend 配置）----
# 前端子路径构建参数：compose 透传给 vite（静态资源、router base、API 前缀）。
VITE_BASE_PATH=/watchtower/
# 前端/后端容器只绑宿主机回环，由门户网关反代；禁止改绑外网卡地址。
FRONTEND_HTTP_BIND=127.0.0.1:8080
BACKEND_HTTP_BIND=127.0.0.1:8000
