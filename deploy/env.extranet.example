# InfoWatchtower extranet（外网发布者形态）环境模板。
# 复制到 /srv/infowatchtower/.env.extranet 并替换所有 REPLACE_WITH_* 值，不要提交真实密钥。
# 配套 compose：deploy/docker-compose.extranet.yml。
# 形态约束（config/contracts/deployment_modes.json）：SYNC_SERVICE_TOKENS 为空启动失败；
# feed 端点只认 Bearer service token，绝不接受登录 cookie。

APP_ENV=production
APP_VERSION=0.1.0
APP_BASE_URL=https://watchtower.example.com
ENABLE_DOCS=false
CORS_ORIGINS=https://watchtower.example.com

# ---- 部署拓扑 ----
DEPLOY_MODE=extranet
INSTANCE_ID=extranet-main
# extranet 默认开启 CSRF，不要设为 false。
AUTH_CSRF_ENABLED=true
EMBED_FRAME_ANCESTORS="'self'"
AUTH_TRUSTED_PROXY_CIDRS=

DATABASE_URL=postgresql+psycopg://infowatchtower:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@postgres:5432/infowatchtower
REDIS_URL=redis://redis:6379/0

BACKUP_KEEP=14

POSTGRES_DB=infowatchtower
POSTGRES_USER=infowatchtower
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD

# extranet 推荐行业标准 SSO（oidc）；也允许 public_password（邀请制）。
AUTH_MODE=oidc
AUTH_SESSION_SECRET=REPLACE_WITH_32_BYTE_RANDOM_SESSION_SECRET
AUTH_SESSION_COOKIE=infowatchtower_session
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=43200
AUTH_AUTO_PROVISION=true
AUTH_DEFAULT_ROLE=viewer

# ---- OIDC（AUTH_MODE=oidc 时必填：CLIENT_ID + ISSUER 或显式端点，缺失启动失败）----
OIDC_ISSUER=https://idp.example.com
OIDC_CLIENT_ID=REPLACE_WITH_OIDC_CLIENT_ID
OIDC_CLIENT_SECRET=REPLACE_WITH_OIDC_CLIENT_SECRET
OIDC_REDIRECT_URL=https://watchtower.example.com/api/auth/oidc/callback
OIDC_POST_LOGIN_REDIRECT_URL=https://watchtower.example.com/
OIDC_SCOPES=openid email profile
OIDC_CLAIM_EXTERNAL_ID=sub
OIDC_CLAIM_EMPLOYEE_NO=employee_no
OIDC_CLAIM_USERNAME=preferred_username
OIDC_CLAIM_DISPLAY_NAME=name
OIDC_CLAIM_DEPARTMENT=department
OIDC_CLAIM_EMAIL=email
# IdP 不提供 issuer 发现时，改用显式端点：
# OIDC_AUTHORIZATION_ENDPOINT=https://idp.example.com/oauth2/authorize
# OIDC_TOKEN_ENDPOINT=https://idp.example.com/oauth2/token
# OIDC_USERINFO_ENDPOINT=https://idp.example.com/oauth2/userinfo
# 自动补写本地 membership（只补 viewer 级，不授 super_admin）：
# AUTH_DEFAULT_WORKSPACE_CODES=planning_intel:viewer
# AUTH_DEPARTMENT_WORKSPACE_MAP=规划部:planning_intel:viewer

# ---- feed 发布（sync publisher）----
# 必填（为空启动失败）。逗号分隔多个 Bearer token，每个内网消费者一个，便于轮换吊销。
SYNC_SERVICE_TOKENS=REPLACE_WITH_SERVICE_TOKEN_FOR_INTRANET

INGESTION_SCHEDULER_ENABLED=true
INGESTION_SCHEDULER_DAILY_TIME=09:00
INGESTION_SCHEDULER_TIMEZONE=Asia/Shanghai
INGESTION_SCHEDULER_WORKSPACE_CODE=planning_intel
INGESTION_SCHEDULER_SOURCE_TYPES=rss,paper_rss,page_manual,page_monitor,wiseflow
INGESTION_CONCURRENCY=8
INGESTION_SOURCE_TIMEOUT_SECONDS=25
INGESTION_MAX_ITEMS_PER_SOURCE=100
# 自建 RSSHub 实例地址（可选），说明见 env.production.example。
RSSHUB_BASE_URL=
SCHEDULER_JOB_MODE=daily_pipeline
DAILY_PIPELINE_RUN_INGESTION=true
DAILY_PIPELINE_CREATE_DAILY_DRAFT=true
DAILY_PIPELINE_RECOMMENDATION_LIMIT=15
DAILY_PIPELINE_SOURCE_DAILY_LIMIT=2
DAILY_PIPELINE_DAY_OFFSET_DAYS=-1

# Optional model provider. Keep disabled until the key is configured and cost is approved.
MINIMAX_GENERATION_ENABLED=false
# MINIMAX_API_KEY=REPLACE_WITH_MINIMAX_API_KEY
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_MAX_TOKENS=3200
MINIMAX_TEMPERATURE=0.4
MINIMAX_RETRY_TIMES=3
MINIMAX_RETRY_BACKOFF_SECONDS=8

# ---- compose 侧变量（TLS 收口，C-6）----
# 启用可选 caddy profile：docker compose --profile tls up -d。
# CADDY_DOMAIN=watchtower.example.com
# FRONTEND_HTTP_PORT=127.0.0.1:8080
