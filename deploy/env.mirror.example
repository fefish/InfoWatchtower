# InfoWatchtower mirror 预设环境模板（--preset mirror）。
# 形态：standalone/cloud 站点，本地不采集，只从我们的外部部署拉取成果
# （sync consumer pull：日报/成品新闻等经外部实例发布后单向进入本站）。
# 复制到 /srv/infowatchtower/.env.production 并替换所有 REPLACE_WITH_* 值。
# Do not commit real secrets.
#
# 组合说明（启动自检放行的合法组合）：
#   DEPLOY_MODE=cloud（或 standalone）
#   CAPABILITY_INGESTION=false      —— 本地采集关闭（scheduler/worker/API 采集入口全部拒绝）
#   CAPABILITY_SYNC_CONSUMER=true   —— 打开消费端能力
#   SYNC_PULL_ENABLED=true          —— 定时从远端 /api/sync/feed 拉取
#   SYNC_REMOTE_BASE_URL/TOKEN      —— 远端外部部署地址与 Bearer token（必填，缺失拒启）

APP_ENV=production
APP_VERSION=0.1.0
APP_BASE_URL=https://mirror.infowatchtower.example.com
ENABLE_DOCS=false
CORS_ORIGINS=https://mirror.infowatchtower.example.com

# ---- 部署拓扑 ----
DEPLOY_MODE=cloud
INSTANCE_ID=mirror-main
AUTH_CSRF_ENABLED=true
EMBED_FRAME_ANCESTORS="'self'"
AUTH_TRUSTED_PROXY_CIDRS=

# ---- mirror 能力开关（本模板核心）----
CAPABILITY_INGESTION=false
CAPABILITY_SYNC_CONSUMER=true

# ---- 同步链路（拉取我们的外部部署成果）----
SYNC_REMOTE_BASE_URL=https://extranet.example.com
SYNC_REMOTE_TOKEN=REPLACE_WITH_SYNC_REMOTE_TOKEN
SYNC_PULL_ENABLED=true
SYNC_PULL_INTERVAL_SECONDS=900
# SYNC_FAILED_INBOX_AUTO_RETRY_ENABLED=true
# SYNC_FAILED_INBOX_RETRY_BASE_SECONDS=300
# SYNC_FAILED_INBOX_RETRY_MAX_SECONDS=3600
# SYNC_FAILED_INBOX_RETRY_MAX_ATTEMPTS=5
# SYNC_FAILED_INBOX_RETRY_LIMIT=50

DATABASE_URL=postgresql+psycopg://infowatchtower:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@postgres:5432/infowatchtower
REDIS_URL=redis://redis:6379/0

BACKUP_KEEP=14

POSTGRES_DB=infowatchtower
POSTGRES_USER=infowatchtower
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD

AUTH_MODE=public_password
AUTH_SESSION_SECRET=REPLACE_WITH_32_BYTE_RANDOM_SESSION_SECRET
AUTH_SESSION_COOKIE=infowatchtower_session
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=43200
AUTH_AUTO_PROVISION=false
AUTH_DEFAULT_ROLE=viewer
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
# Leave password empty to use the /setup first-run wizard. Fill it only for unattended bootstrap.
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员

AUTH_HEADER_EMPLOYEE_NO=X-Employee-No
AUTH_HEADER_DISPLAY_NAME=X-Employee-Name
AUTH_HEADER_DEPARTMENT=X-Department
AUTH_HEADER_EMAIL=X-Email

# mirror 不采集：调度器关闭（worker 能力门是第二道防线），时区键保留供部署校验。
INGESTION_SCHEDULER_ENABLED=false
INGESTION_SCHEDULER_TIMEZONE=Asia/Shanghai
INGESTION_SCHEDULER_WORKSPACE_CODE=planning_intel
SCHEDULER_JOB_MODE=daily_pipeline
DAILY_PIPELINE_RUN_INGESTION=false
DAILY_PIPELINE_CREATE_DAILY_DRAFT=false

# mirror 不做本地生成，模型能力保持关闭（GENERATION_* 为首选口径，
# 旧 MINIMAX_GENERATION_ENABLED 仍作兼容回退）。
GENERATION_ENABLED=false
