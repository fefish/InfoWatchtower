# InfoWatchtower production environment template.
# Copy to /srv/infowatchtower/.env.production and replace every REPLACE_WITH_* value.
# Do not commit real secrets.

APP_ENV=production
APP_VERSION=0.1.0
APP_BASE_URL=https://infowatchtower.example.com
ENABLE_DOCS=false
CORS_ORIGINS=https://infowatchtower.example.com

# ---- 部署拓扑（四形态：standalone / cloud / intranet / extranet）----
# 契约：config/contracts/deployment_modes.json；env 矩阵：docs/deployment/deployment-ops.md §1.1。
# 本模板对应云主机官方版（cloud）；intranet / extranet 形态请改用
# deploy/env.intranet.example / deploy/env.extranet.example。
#
# ---- 三种启动预设（deploy/install.sh --preset rss-only|full|mirror，默认 full）----
# 1) full（本模板现状）：全量能力，不写 INGESTION_SOURCE_TYPES 允许清单（空 = 全部允许）。
# 2) rss-only：平台部署只抓 RSS 类信息源。设置
#      INGESTION_SOURCE_TYPES=rss,paper_rss
#    抓取 run 内部按清单过滤启用源，不在清单的源计入 run 摘要 skipped_type_disabled；
#    合法取值为 config/contracts/source_fields.json 的 11 类 + wechat，非法值启动拒绝。
# 3) mirror：本地不采集，只从我们的外部部署拉取成果。组合为
#      CAPABILITY_INGESTION=false + CAPABILITY_SYNC_CONSUMER=true
#      + SYNC_PULL_ENABLED=true + SYNC_REMOTE_BASE_URL/SYNC_REMOTE_TOKEN
#    完整样例见 deploy/env.mirror.example。
DEPLOY_MODE=cloud
# 实例标识（同步链路与 /api/meta/runtime 使用）；留空回落为 DEPLOY_MODE 值。
INSTANCE_ID=cloud-main
# cloud/intranet/extranet 默认开启 CSRF（双提交 cookie）；除 standalone 本地调试外不要设为 false。
AUTH_CSRF_ENABLED=true
# CSP frame-ancestors 白名单（HTML 与 API 响应共用）。默认仅允许同源；
# intranet 形态填门户域，如 EMBED_FRAME_ANCESTORS="'self' https://portal.example.com"。
EMBED_FRAME_ANCESTORS="'self'"
# 可信反代网段兜底校验（可选）：非空时 backend 校验直连来源，逗号分隔 CIDR。
AUTH_TRUSTED_PROXY_CIDRS=

# ---- 同步链路（extranet 发布者 / intranet 消费者；cloud/standalone 不参与，保持注释）----
# extranet 必填（为空启动失败），逗号分隔多个 Bearer token：
# SYNC_SERVICE_TOKENS=REPLACE_WITH_SERVICE_TOKEN_A,REPLACE_WITH_SERVICE_TOKEN_B
# intranet 拉取端配置：
# SYNC_REMOTE_BASE_URL=https://extranet.example.com
# SYNC_REMOTE_TOKEN=REPLACE_WITH_SYNC_REMOTE_TOKEN
# SYNC_PULL_ENABLED=true
# SYNC_PULL_INTERVAL_SECONDS=900
# SYNC_FAILED_INBOX_AUTO_RETRY_ENABLED=true
# SYNC_FAILED_INBOX_RETRY_BASE_SECONDS=300
# SYNC_FAILED_INBOX_RETRY_MAX_SECONDS=3600
# SYNC_FAILED_INBOX_RETRY_MAX_ATTEMPTS=5
# SYNC_FAILED_INBOX_RETRY_LIMIT=50

# ---- OIDC（AUTH_MODE=oidc 时启用；cloud 可选，完整样例见 deploy/env.extranet.example）----
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=REPLACE_WITH_OIDC_CLIENT_ID
# OIDC_CLIENT_SECRET=REPLACE_WITH_OIDC_CLIENT_SECRET
# OIDC_REDIRECT_URL=https://infowatchtower.example.com/api/auth/oidc/callback
# OIDC_POST_LOGIN_REDIRECT_URL=https://infowatchtower.example.com/

# ---- 前端构建参数（非运行时 env）----
# 子路径部署（如内网门户 /watchtower/）需在构建镜像时传入，默认 /：
#   docker build --build-arg VITE_BASE_PATH=/watchtower/ frontend/
# intranet compose 已通过 build args 透传，见 deploy/docker-compose.intranet.yml。

# ---- TLS 收口（可选 caddy profile，C-6）----
# 启用：docker compose --profile tls up -d；caddy 监听 80/443 并按域名自动签发证书。
# CADDY_DOMAIN=infowatchtower.example.com
# 启用 tls profile 时把前端 nginx 的宿主机端口让给 caddy 并只绑回环：
# FRONTEND_HTTP_PORT=127.0.0.1:8080

DATABASE_URL=postgresql+psycopg://infowatchtower:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@postgres:5432/infowatchtower
REDIS_URL=redis://redis:6379/0

BACKUP_KEEP=14

POSTGRES_DB=infowatchtower
POSTGRES_USER=infowatchtower
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD

AUTH_MODE=public_password
AUTH_SESSION_SECRET=REPLACE_WITH_32_BYTE_RANDOM_SESSION_SECRET
AUTH_SESSION_COOKIE=infowatchtower_session
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=43200
AUTH_AUTO_PROVISION=false
AUTH_DEFAULT_ROLE=viewer
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
# Leave password empty to use the /setup first-run wizard. Fill it only for unattended bootstrap.
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员

AUTH_HEADER_EMPLOYEE_NO=X-Employee-No
AUTH_HEADER_DISPLAY_NAME=X-Employee-Name
AUTH_HEADER_DEPARTMENT=X-Department
AUTH_HEADER_EMAIL=X-Email

INGESTION_SCHEDULER_ENABLED=true
# 推荐 12:00（代码默认值）：每天中午跑昨日窗口，配合 DAILY_PIPELINE_DAY_OFFSET_DAYS=-1
INGESTION_SCHEDULER_DAILY_TIME=12:00
INGESTION_SCHEDULER_TIMEZONE=Asia/Shanghai
INGESTION_SCHEDULER_WORKSPACE_CODE=planning_intel
INGESTION_SCHEDULER_SOURCE_TYPES=rss,paper_rss,page_manual,page_monitor,wiseflow
# 部署级采集类型允许清单（rss-only 预设用；空/缺省 = 全部允许 = full 预设）。
# 与上面的 SCHEDULER_SOURCE_TYPES 不同：本清单在 run 内部过滤启用源，
# 不在清单的源计入 run 摘要 skipped_type_disabled。
# INGESTION_SOURCE_TYPES=rss,paper_rss
INGESTION_CONCURRENCY=8
INGESTION_SOURCE_TIMEOUT_SECONDS=25
INGESTION_MAX_ITEMS_PER_SOURCE=100
# 自建 RSSHub 实例地址（可选）。配置后 rsshub.app 前缀的源自动改走该实例，
# 是 X（Twitter）等路由可用的前提；留空则继续访问公共 rsshub.app（大概率 403）。
RSSHUB_BASE_URL=
# Optional Semantic Scholar API key for paper_api provider rate limits.
# Keep real keys in the deployment secret store or .env.production only.
# SEMANTIC_SCHOLAR_API_KEY=REPLACE_WITH_SEMANTIC_SCHOLAR_API_KEY
SCHEDULER_JOB_MODE=daily_pipeline
DAILY_PIPELINE_RUN_INGESTION=true
DAILY_PIPELINE_CREATE_DAILY_DRAFT=true
DAILY_PIPELINE_RECOMMENDATION_LIMIT=15
DAILY_PIPELINE_SOURCE_DAILY_LIMIT=2
DAILY_PIPELINE_DAY_OFFSET_DAYS=-1
# Catch-up window (seconds) for triggers missed while the scheduler was down:
# within the window the job is enqueued on the next tick, beyond it the day is
# skipped and must be backfilled manually (default 3600).
SCHEDULER_MISSED_WINDOW_SECONDS=3600

# Optional model provider (GENERATION_* family, implemented 2026-07-08).
# Keep disabled until the key is configured and cost is approved.
# Startup checks (config/contracts/deployment_modes.json, revised 2026-07-08 WP4-B):
# fail-fast when provider is outside the llm_providers.json catalog
# [openai, anthropic, deepseek, moonshot, zhipu_glm, minimax, openrouter,
# ollama, custom] (+ deprecated alias openai_compatible = custom), or when
# custom/openai_compatible has no GENERATION_BASE_URL.
# GENERATION_ENABLED=true with an empty env key is only a startup WARNING:
# the key can be registered at runtime via the UI credential store
# (llm_provider_credentials, Fernet-encrypted, masked display only); until
# then generation degrades to rule-fallback drafts.
GENERATION_ENABLED=false
GENERATION_PROVIDER=minimax
# GENERATION_API_KEY=REPLACE_WITH_GENERATION_API_KEY
# or: GENERATION_API_KEY_REF=env:MY_LLM_KEY / file:/run/secrets/llm_key
GENERATION_BASE_URL=https://api.minimaxi.com/v1
GENERATION_MODEL=MiniMax-M2.7-highspeed
GENERATION_MAX_TOKENS=3200
GENERATION_TEMPERATURE=0.4
GENERATION_RETRY_TIMES=3
GENERATION_RETRY_BACKOFF_SECONDS=8
# Legacy MINIMAX_* variables still work as per-field fallbacks during the
# deprecation window (GENERATION_* wins when both are set):
# MINIMAX_GENERATION_ENABLED=false
# MINIMAX_API_KEY=REPLACE_WITH_MINIMAX_API_KEY
