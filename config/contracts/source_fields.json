    "backfill_days": "backfill_days",
    "primary_category": "folo_metadata.primary_category",
    "secondary_category": "folo_metadata.secondary_category",
    "info_category": "folo_metadata.info_category",
    "topic_flags.is_model_related": "folo_metadata.is_model_related",
    "topic_flags.is_inference_related": "folo_metadata.is_inference_related",
    "topic_flags.is_agent_related": "folo_metadata.is_agent_related",
    "topic_flags.is_application_related": "folo_metadata.is_application_related",
    "topic_flags.is_device_vendor_related": "folo_metadata.is_device_vendor_related",
    "topic_flags.is_telco_related": "folo_metadata.is_telco_related",
    "topic_flags.is_cloud_related": "folo_metadata.is_cloud_related",
    "topic_flags.is_hardware_related": "folo_metadata.is_hardware_related",
    "topic_flags.is_core_competency_related": "folo_metadata.is_core_competency_related",
    "metadata": "origin and folo_metadata",
    "visibility_scope": "public",
    "sync_policy": "public_to_intranet"
  },
  "legacy_page_mapping": {
    "domain_code": "ai",
    "source_type": "page_manual when type == manual else page_monitor",
    "name": "name",
    "url": "page_url for listing, articles[].url for manual entries",
    "enabled": true,
    "default_focus_id": "default_focus_id",
    "backfill_days": "backfill_days",
    "fetch_config.type": "type",
    "fetch_config.page_url": "page_url",
    "fetch_config.href_contains": "href_contains",
    "fetch_config.exclude_exact": "exclude_exact",
    "fetch_config.max_links": "max_links",
    "fetch_config.articles": "articles",
    "metadata": "full legacy page source object",
    "visibility_scope": "public",
    "sync_policy": "public_to_intranet"
  },
  "seed_counts": {
