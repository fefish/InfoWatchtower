{
  "schema_version": 1,
  "description": "Canonical data-source contract and legacy seed mapping.",
  "source_seed_files": {
    "legacy_wiseflow": "config/seeds/legacy/wiseflow_sources.json",
    "legacy_rss": "config/seeds/legacy/rss_sources.json",
    "legacy_page": "config/seeds/legacy/page_sources.json",
    "legacy_all_index": "config/seeds/legacy/all_sources.index.json",
    "legacy_human_registry": "config/seeds/legacy/source_registry.md",
    "legacy_folo_catalog": "config/seeds/legacy/source_catalog/folo-rss-link-classification-unified-folo-cli-supplemented.csv"
  },
  "source_types": [
    "wiseflow",
    "rss",
    "page_monitor",
    "page_manual",
    "crawler",
    "paper_rss",
    "paper_api",
    "paper_page",
    "manual",
    "internal"
  ],
  "canonical_data_source_fields": [
    {"name": "id", "type": "uuid", "required": true, "notes": "Internal primary key."},
    {"name": "domain_code", "type": "string", "required": true, "default": "ai", "notes": "Strategic intelligence board. Examples: ai, hardware, semiconductor, robotics, policy_market, competitor."},
    {"name": "source_type", "type": "enum", "required": true, "notes": "wiseflow/rss/page_monitor/page_manual/crawler/paper_rss/paper_api/paper_page/manual/internal."},
    {"name": "name", "type": "string", "required": true, "legacy_rss": "name", "legacy_page": "name"},
    {"name": "url", "type": "string", "required": false, "legacy_rss": "feed_url", "legacy_page": "page_url or articles[].url", "legacy_wiseflow": "SOURCE_READ_INFO_URL or derived from SOURCE_API_BASE"},
    {"name": "enabled", "type": "boolean", "required": true, "legacy_rss": "enabled", "legacy_page": "true"},
    {"name": "default_focus_id", "type": "integer", "required": true, "legacy_rss": "default_focus_id", "legacy_page": "default_focus_id"},
    {"name": "backfill_days", "type": "integer", "required": true, "legacy_rss": "backfill_days", "legacy_page": "backfill_days"},
    {"name": "fetch_interval_minutes", "type": "integer", "required": false, "default": 1440},
    {"name": "trust_level", "type": "integer", "required": false, "default": 50},
    {"name": "daily_source_limit", "type": "integer", "required": false, "default": 2},
    {"name": "visibility_scope", "type": "enum", "required": true, "default": "public", "notes": "public/internal/restricted. Used by sync and export policy."},
    {"name": "sync_policy", "type": "enum", "required": true, "default": "public_to_intranet", "notes": "none/public_to_intranet/two_way_config/manual_only."},
    {"name": "credential_ref", "type": "string", "required": false, "notes": "Reference to environment-specific credentials. Secrets must not be stored in synced source config."},
    {"name": "primary_category", "type": "string", "required": false, "legacy_rss": "folo_metadata.primary_category"},
    {"name": "secondary_category", "type": "string", "required": false, "legacy_rss": "folo_metadata.secondary_category"},
    {"name": "info_category", "type": "string", "required": false, "legacy_rss": "folo_metadata.info_category"},
    {"name": "topic_flags", "type": "object", "required": false, "notes": "Model/inference/agent/application/telco/cloud/hardware/core-competency flags."},
    {"name": "fetch_config", "type": "json", "required": false, "notes": "Wiseflow read_info config, RSS URL, page listing rules, selectors, crawler adapter name, API params."},
    {"name": "paper_config", "type": "json", "required": false, "notes": "arxiv categories, DOI/API settings, venue filters, citation providers."},
    {"name": "metadata", "type": "json", "required": false, "legacy_rss": "folo_metadata plus origin", "legacy_page": "full page source object"},
    {"name": "created_at", "type": "datetime", "required": true},
    {"name": "updated_at", "type": "datetime", "required": true}
  ],
  "legacy_wiseflow_mapping": {
    "domain_code": "ai",
    "source_type": "wiseflow",
    "name": "name",
    "enabled": "enabled",
    "default_focus_id": "default_focus_id",
    "fetch_config.base_url_env": "base_url_env",
    "fetch_config.read_info_url_env": "read_info_url_env",
    "fetch_config.page_size_env": "page_size_env",
    "fetch_config.required_full_sync_endpoint": "required_full_sync_endpoint",
    "fetch_config.do_not_use_for_full_sync": "do_not_use_for_full_sync",
    "metadata": "notes and metadata",
    "visibility_scope": "public",
    "sync_policy": "public_to_intranet"
  },
  "legacy_rss_mapping": {
