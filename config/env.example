# InfoWatchtower environment example.
# Copy values into config/.env for local development or /srv/infowatchtower/.env.production for deployment.
# Do not commit real secrets.

APP_ENV=development
APP_VERSION=0.1.0
APP_BASE_URL=http://localhost:8000
ENABLE_DOCS=true
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql+psycopg://infowatchtower:change_me@postgres:5432/infowatchtower
REDIS_URL=redis://redis:6379/0

POSTGRES_DB=infowatchtower
POSTGRES_USER=infowatchtower
POSTGRES_PASSWORD=change_me

AUTH_MODE=public_password
AUTH_SESSION_SECRET=change_me_to_a_long_random_secret
AUTH_SESSION_COOKIE=infowatchtower_session
AUTH_SESSION_TTL_SECONDS=43200
AUTH_AUTO_PROVISION=false
AUTH_DEFAULT_ROLE=viewer
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change_me_before_deploy
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=规划部管理员

AUTH_HEADER_EMPLOYEE_NO=X-Employee-No
AUTH_HEADER_DISPLAY_NAME=X-Employee-Name
AUTH_HEADER_DEPARTMENT=X-Department
AUTH_HEADER_EMAIL=X-Email

# Daily pipeline scheduler. Disabled by default; API/manual runs still work.
# The historical INGESTION_* names control scheduler source scope. If
# INGESTION_SCHEDULER_DAILY_TIME is set, the scheduler runs at that wall-clock
# time in INGESTION_SCHEDULER_TIMEZONE; otherwise it keeps interval mode.
INGESTION_SCHEDULER_ENABLED=false
INGESTION_SCHEDULER_INTERVAL_SECONDS=86400
INGESTION_SCHEDULER_DAILY_TIME=09:00
INGESTION_SCHEDULER_TIMEZONE=Asia/Shanghai
INGESTION_SCHEDULER_WORKSPACE_CODE=planning_intel
INGESTION_SCHEDULER_SOURCE_TYPES=rss,paper_rss,page_manual,page_monitor,wiseflow
# Optional safety limit for each scheduled run. Leave commented for no limit.
# INGESTION_SCHEDULER_LIMIT=10
INGESTION_CONCURRENCY=8
INGESTION_SOURCE_TIMEOUT_SECONDS=25
SCHEDULER_JOB_MODE=daily_pipeline
DAILY_PIPELINE_RUN_INGESTION=true
DAILY_PIPELINE_CREATE_DAILY_DRAFT=true
DAILY_PIPELINE_RECOMMENDATION_LIMIT=15
DAILY_PIPELINE_SOURCE_DAILY_LIMIT=2
# Use -1 for a morning job that generates yesterday's daily report.
DAILY_PIPELINE_DAY_OFFSET_DAYS=-1

# Optional model providers.
# MiniMax generation is off by default in code to avoid accidental cost during tests.
# Uncomment in config/.env or production env when selected recommendations should be
# rewritten by MiniMax instead of deterministic rule fallback.
# MINIMAX_GENERATION_ENABLED=true
# MINIMAX_API_KEY=
# MiniMax 生成链路按旧参考脚本已验证的中国区 OpenAI-compatible 接口调用。
# 旧 .env 里可能残留 MINIMAX_ANTHROPIC_BASE_URL；新系统不会用它覆盖主链路。
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.7-highspeed
# MINIMAX_MAX_TOKENS=3200
# MINIMAX_TEMPERATURE=0.4
# MINIMAX_RETRY_TIMES=3
# MINIMAX_RETRY_BACKOFF_SECONDS=8
