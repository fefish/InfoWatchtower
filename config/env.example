# InfoWatchtower environment example.
# Copy values into config/.env for local development or /srv/infowatchtower/.env.production for deployment.
# Do not commit real secrets.

APP_ENV=development
APP_VERSION=0.1.0
APP_BASE_URL=http://localhost:8000
ENABLE_DOCS=true
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql+psycopg://infowatchtower:change_me@postgres:5432/infowatchtower
REDIS_URL=redis://redis:6379/0

POSTGRES_DB=infowatchtower
POSTGRES_USER=infowatchtower
POSTGRES_PASSWORD=change_me

AUTH_MODE=public_password
AUTH_SESSION_SECRET=change_me_to_a_long_random_secret
AUTH_SESSION_COOKIE=infowatchtower_session
AUTH_SESSION_TTL_SECONDS=43200
AUTH_AUTO_PROVISION=false
AUTH_DEFAULT_ROLE=viewer
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change_me_before_deploy
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=规划部管理员

AUTH_HEADER_EMPLOYEE_NO=X-Employee-No
AUTH_HEADER_DISPLAY_NAME=X-Employee-Name
AUTH_HEADER_DEPARTMENT=X-Department
AUTH_HEADER_EMAIL=X-Email

# Ingestion scheduler. Disabled by default; API/manual runs still work.
INGESTION_SCHEDULER_ENABLED=false
INGESTION_SCHEDULER_INTERVAL_SECONDS=86400
INGESTION_SCHEDULER_WORKSPACE_CODE=planning_intel
INGESTION_SCHEDULER_SOURCE_TYPES=rss,paper_rss
# Optional safety limit for each scheduled run. Leave commented for no limit.
# INGESTION_SCHEDULER_LIMIT=10

# Optional model providers.
OPENAI_API_KEY=
MODEL_PROVIDER=openai
MODEL_NAME=
